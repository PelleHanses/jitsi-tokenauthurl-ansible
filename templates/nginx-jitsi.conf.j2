# roles/jitsi_nginx_proxy/templates/jitsi.conf.j2
# Genererad av Ansible – redigera inte manuellt

# HTTP → HTTPS redirect
server {
    listen 80;
    server_name {{ jitsi_public_hostname }};

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS – huvudvhost
server {
    listen 443 ssl;
    http2 on;
    server_name {{ jitsi_public_hostname }};

    # ── SSL ──────────────────────────────────────────────────────
    ssl_certificate     /etc/nginx/ssl/jitsi.crt;
    ssl_certificate_key /etc/nginx/ssl/jitsi.key;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # ── Loggning ─────────────────────────────────────────────────
    access_log {{ nginx_access_log }};
    error_log  {{ nginx_error_log }};

    # ── Generella proxy-headers ──────────────────────────────────
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Timeouts – viktigt för Jitsi-sessioner
    proxy_read_timeout    {{ nginx_proxy_read_timeout }};
    proxy_send_timeout    {{ nginx_proxy_send_timeout }};
    proxy_connect_timeout {{ nginx_proxy_connect_timeout }};

    # ── HTTP → Jitsi web-container ───────────────────────────────
    location / {
        proxy_pass http://{{ jitsi_web_upstream }};
    }

    # ── XMPP BOSH (HTTP long-polling) ────────────────────────────
    location /http-bind {
        proxy_pass         http://{{ jitsi_web_upstream }}/http-bind;
        proxy_set_header   X-Forwarded-For $remote_addr;
        proxy_buffering    off;
        proxy_cache        off;
    }

    # ── XMPP WebSocket ───────────────────────────────────────────
    location /xmpp-websocket {
        proxy_pass          http://{{ jitsi_web_upstream }}/xmpp-websocket;
        proxy_http_version  1.1;
        proxy_set_header    Upgrade    $http_upgrade;
        proxy_set_header    Connection "upgrade";
        proxy_set_header    Host       $host;
        proxy_read_timeout  {{ nginx_proxy_read_timeout }};
    }

    # ── Colibri WebSocket (JVB-signalering) ──────────────────────
    location ~ ^/colibri-ws/ {
        proxy_pass          http://{{ jitsi_web_upstream }};
        proxy_http_version  1.1;
        proxy_set_header    Upgrade    $http_upgrade;
        proxy_set_header    Connection "upgrade";
        proxy_set_header    Host       $host;
        proxy_read_timeout  {{ nginx_proxy_read_timeout }};
    }
    # ── Nordeck adapter – OIDC-flödet ────────────────────────────
    location /oidc/ {
        proxy_pass http://jitsi-keycloak-adapter:9000/oidc/;
        proxy_http_version 1.1;
    }
}
