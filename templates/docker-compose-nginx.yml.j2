---
# docker-compose-proxy.yml
# Nginx reverse proxy framför Jitsi Meet
# Läs in med: docker compose -f docker-compose-proxy.yml up -d
# Förutsätter att Jitsi-stacken körs i samma Docker-nätverk (meet.jitsi)
# och att web-containern är nåbar på port 8080 internt.

x-podman:
  in_pod: false

services:

  nginx-proxy:
    image: {{ nginx_info }}:{{ nginx_version }}
    container_name: {{ org_name }}_nginx-proxy
    restart: unless-stopped
    ports:
      - "{{ nginx_port_http }}:80"
      - "{{ nginx_port_https }}:443"
    volumes:
      # Nginx-konfiguration genererad av Ansible
      - ./nginx/conf.d:/etc/nginx/conf.d:ro
      # SSL-certifikat (self-signed i teststadiet, byts ut mot officiellt)
      - ./nginx/ssl:/etc/nginx/ssl:ro
      # Valfri loggkatalog
      - ./nginx/logs:/var/log/nginx
    environment:
      - NGINX_ENVSUBST_TEMPLATE_DIR=/etc/nginx/conf.d
    networks:
      - meet.jitsi
    depends_on: []   # Lägg till web-containerns service-namn om du kör i samma stack

networks:
  meet.jitsi:
     #driver: bridge
    external: true   # Nätverket skapas av den ordinarie docker-compose.yml
